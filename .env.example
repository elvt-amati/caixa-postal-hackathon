# Caixa Postal — copy to `.env` and fill in your own AWS credentials.
# We do NOT commit `.env`; it is gitignored.

# 1) AWS credentials — ONE of:
#    (a) Temporary credentials from the hackathon SSO portal
#    (b) aws configure sso + `aws sso login`
#    (c) IAM access key + secret (less safe)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# 2) Caixa backend — normally you don't change these; defaults wire to our shared infra
CAIXA_TABLE=caixa-items
CAIXA_BUCKET=caixa-446394402238
SES_FROM=amati.silva@elevata.io
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# 3) Rate-limit knobs (optional)
# CAIXA_PITCH_MAX_PARALLEL=4

# 4) Auth — OFF by default (anon user). Flip to `true` + fill the Cognito fields
#    when you want Hosted UI + per-user isolation.
CAIXA_AUTH_ENABLED=false
# CAIXA_AUTH_OIDC_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/<POOL_ID>
# CAIXA_AUTH_OIDC_CLIENT_ID=
# CAIXA_AUTH_OIDC_CLIENT_SECRET=
# CAIXA_PUBLIC_URL=https://caixa.example.com
# CAIXA_AUTH_ALLOWED_EMAILS=

# 5) AgentCore Gateway (optional — for participants calling Gateway directly from a custom agent)
# CAIXA_GATEWAY_URL=https://caixa-gateway-xxx.gateway.bedrock-agentcore.us-east-1.amazonaws.com/mcp
# CAIXA_COGNITO_DOMAIN=https://caixa-446394402238.auth.us-east-1.amazoncognito.com
# CAIXA_COGNITO_CLIENT_ID=
# CAIXA_COGNITO_CLIENT_SECRET=
# CAIXA_COGNITO_SCOPES=caixa-api/read caixa-api/write
